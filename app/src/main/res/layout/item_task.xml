<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="4dp"
    app:cardUseCompatPadding="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Title row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/txtTaskTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Task Title"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#111"
                android:fontFamily="@font/poppins"/>

            <!-- Completion request badge -->
            <TextView
                android:id="@+id/txtCompletionBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⏳ Review"
                android:textSize="11sp"
                android:fontFamily="@font/poppins"
                android:textColor="#FFFFFF"
                android:background="#FF8C00"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:visibility="gone"/>

        </LinearLayout>

        <!-- Assigned to (admin view) -->
        <TextView
            android:id="@+id/txtAssignedTo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="👤 Employee Name"
            android:textSize="13sp"
            android:fontFamily="@font/poppins"
            android:textColor="#555"
            android:visibility="gone"/>

        <!-- Priority + Status row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">

            <TextView
                android:id="@+id/txtTaskPriority"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🟡 Medium"
                android:textSize="12sp"
                android:fontFamily="@font/poppins"
                android:textColor="#555"/>

            <View
                android:layout_width="1dp"
                android:layout_height="14dp"
                android:background="#CCCCCC"
                android:layout_marginHorizontal="10dp"/>

            <TextView
                android:id="@+id/txtTaskStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pending"
                android:textSize="12sp"
                android:textStyle="bold"
                android:fontFamily="@font/poppins"
                android:textColor="#FF8C00"/>

        </LinearLayout>

        <!-- Progress row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">

            <ProgressBar
                android:id="@+id/taskProgressBar"
                style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                android:layout_width="0dp"
                android:layout_height="8dp"
                android:layout_weight="1"
                android:max="100"
                android:progress="0"
                android:progressTint="#1E90FF"/>

            <TextView
                android:id="@+id/txtTaskProgress"
                android:layout_width="40dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="0%"
                android:textSize="12sp"
                android:fontFamily="@font/poppins"
                android:textColor="#1E90FF"
                android:gravity="end"/>

        </LinearLayout>

        <!-- Deadline + Date row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <TextView
                android:id="@+id/txtTaskDeadline"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="📅 Due: —"
                android:textSize="12sp"
                android:fontFamily="@font/poppins"
                android:textColor="#E53935"
                android:visibility="gone"/>

            <TextView
                android:id="@+id/txtTaskTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="01 Jan 2026"
                android:textSize="11sp"
                android:fontFamily="@font/poppins"
                android:textColor="#888"/>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
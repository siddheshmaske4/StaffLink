<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/admin_page_gradient">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="18dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_back_black"
                android:padding="8dp"
                android:contentDescription="Back"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Task Detail"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#2C3A47"
                android:layout_marginStart="12dp"
                android:fontFamily="@font/poppins"/>
        </LinearLayout>

        <!-- Main card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:id="@+id/txtTaskTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Task Title"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/poppins"
                    android:textColor="#111"/>

                <TextView
                    android:id="@+id/txtSeenStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Not seen"
                    android:textSize="12sp"
                    android:fontFamily="@font/poppins"
                    android:textColor="#888"/>

                <TextView
                    android:id="@+id/txtAssignedBy"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Assigned by: Admin"
                    android:textSize="12sp"
                    android:fontFamily="@font/poppins"
                    android:textColor="#888"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#EEEEEE"
                    android:layout_marginVertical="12dp"/>

                <TextView
                    android:id="@+id/txtTaskDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Task description."
                    android:textSize="15sp"
                    android:fontFamily="@font/poppins"
                    android:textColor="#333"
                    android:lineSpacingExtra="4dp"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#EEEEEE"
                    android:layout_marginVertical="12dp"/>

                <TextView
                    android:id="@+id/txtTaskDeadline"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📅 Due: —"
                    android:textSize="14sp"
                    android:fontFamily="@font/poppins"
                    android:textColor="#E53935"/>

                <TextView
                    android:id="@+id/txtTaskPriority"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Priority: Medium"
                    android:textSize="14sp"
                    android:fontFamily="@font/poppins"
                    android:textColor="#555"/>

                <TextView
                    android:id="@+id/txtTaskStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Status: Pending"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/poppins"
                    android:textColor="#FF8C00"/>

                <TextView
                    android:id="@+id/txtTaskProgress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Progress: 0%"
                    android:textSize="14sp"
                    android:fontFamily="@font/poppins"
                    android:textColor="#1E90FF"/>

                <!-- ── Work Notes (shown to both admin and employee) ────────── -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#EEEEEE"
                    android:layout_marginVertical="12dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📝 Work Notes"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/poppins"
                    android:textColor="#2C3A47"/>

                <TextView
                    android:id="@+id/txtWorkNotes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="No notes added yet"
                    android:textSize="14sp"
                    android:fontFamily="@font/poppins"
                    android:textColor="#555"
                    android:lineSpacingExtra="4dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Employee actions -->
        <LinearLayout
            android:id="@+id/layoutEmployeeActions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="20dp"
            android:visibility="gone">

            <Button
                android:id="@+id/btnMarkSeen"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Mark as Seen"
                android:fontFamily="@font/poppins"
                android:backgroundTint="#607D8B"
                android:textColor="@android:color/white"/>

            <Button
                android:id="@+id/btnStartTask"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Start Task"
                android:fontFamily="@font/poppins"
                android:backgroundTint="#1E90FF"
                android:textColor="@android:color/white"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Update Progress"
                android:textSize="15sp"
                android:textStyle="bold"
                android:fontFamily="@font/poppins"
                android:textColor="#2C3A47"/>

            <SeekBar
                android:id="@+id/seekBarProgress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:max="100"
                android:progress="0"
                android:progressTint="#1E90FF"
                android:thumbTint="#1E90FF"/>

            <!-- ── Work Notes input (employee only) ──────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="📝 Work Notes"
                android:textSize="15sp"
                android:textStyle="bold"
                android:fontFamily="@font/poppins"
                android:textColor="#2C3A47"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Describe what you did. Admin reviews this before approving."
                android:textSize="12sp"
                android:fontFamily="@font/poppins"
                android:textColor="#888"/>

            <EditText
                android:id="@+id/etWorkNotes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="e.g. Fixed the login bug, tested on 3 devices..."
                android:minLines="3"
                android:gravity="top"
                android:fontFamily="@font/poppins"
                android:textSize="14sp"
                android:background="@drawable/bg_input"
                android:padding="12dp"/>

            <Button
                android:id="@+id/btnSaveNotes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Save Notes"
                android:fontFamily="@font/poppins"
                android:backgroundTint="#607D8B"
                android:textColor="@android:color/white"/>

            <Button
                android:id="@+id/btnRequestCompletion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Request Completion"
                android:fontFamily="@font/poppins"
                android:backgroundTint="#2E7D32"
                android:textColor="@android:color/white"/>

        </LinearLayout>

        <!-- Admin actions -->
        <LinearLayout
            android:id="@+id/layoutAdminActions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="20dp"
            android:visibility="gone">

            <LinearLayout
                android:id="@+id/layoutCompletionRequest"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#E8F5E9"
                android:padding="14dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✅ Employee has requested completion"
                    android:textSize="14sp"
                    android:fontFamily="@font/poppins"
                    android:textStyle="bold"
                    android:textColor="#2E7D32"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="12dp">

                    <Button
                        android:id="@+id/btnApprove"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Approve ✓"
                        android:fontFamily="@font/poppins"
                        android:backgroundTint="#2E7D32"
                        android:textColor="@android:color/white"/>

                    <Button
                        android:id="@+id/btnReject"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="10dp"
                        android:text="Reject ✗"
                        android:fontFamily="@font/poppins"
                        android:backgroundTint="#B71C1C"
                        android:textColor="@android:color/white"/>

                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
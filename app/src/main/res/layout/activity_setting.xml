<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/admin_page_gradient"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <!-- ── HEADER ─────────────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="14dp"
            android:layout_marginTop="15dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@android:color/transparent"
                android:src="@drawable/ic_back_black"
                android:contentDescription="Back"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Settings"
                android:textSize="24sp"
                android:textStyle="bold"
                android:fontFamily="@font/poppins"
                android:layout_marginStart="12dp"
                android:textColor="#111827"/>
        </LinearLayout>

        <!-- ── PROFILE SETTINGS TITLE ────────────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Profile Settings"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#111827"
            android:fontFamily="@font/poppins"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="16dp"/>

        <!-- ── PROFILE FORM CARD ──────────────────────────────────────────── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="8dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Name -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Name"
                    android:textSize="14sp"
                    android:textColor="#1F2937"
                    android:fontFamily="@font/poppins"
                    android:layout_marginTop="8dp"/>

                <EditText
                    android:id="@+id/etName"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/edittext_line_background"
                    android:padding="12dp"
                    android:hint="Enter your name"
                    android:textSize="14sp"
                    android:fontFamily="@font/poppins"
                    android:enabled="false"/>

                <!-- Email -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Email"
                    android:textSize="14sp"
                    android:textColor="#1F2937"
                    android:fontFamily="@font/poppins"
                    android:layout_marginTop="12dp"/>

                <EditText
                    android:id="@+id/etEmail"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/edittext_line_background"
                    android:padding="12dp"
                    android:hint="Enter your email"
                    android:inputType="textEmailAddress"
                    android:textSize="14sp"
                    android:fontFamily="@font/poppins"
                    android:enabled="false"/>

                <!-- Phone -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Phone"
                    android:textSize="14sp"
                    android:textColor="#1F2937"
                    android:fontFamily="@font/poppins"
                    android:layout_marginTop="12dp"/>

                <EditText
                    android:id="@+id/etPhone"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/edittext_line_background"
                    android:padding="12dp"
                    android:hint="Enter your phone"
                    android:inputType="phone"
                    android:textSize="14sp"
                    android:fontFamily="@font/poppins"
                    android:enabled="false"/>

                <!-- Department -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Department"
                    android:textSize="14sp"
                    android:textColor="#1F2937"
                    android:fontFamily="@font/poppins"
                    android:layout_marginTop="12dp"/>

                <EditText
                    android:id="@+id/etDepartment"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/edittext_line_background"
                    android:padding="12dp"
                    android:hint="Enter your department"
                    android:textSize="14sp"
                    android:fontFamily="@font/poppins"
                    android:enabled="false"/>

                <!-- Position -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Position"
                    android:textSize="14sp"
                    android:textColor="#1F2937"
                    android:fontFamily="@font/poppins"
                    android:layout_marginTop="12dp"/>

                <EditText
                    android:id="@+id/etPosition"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/edittext_line_background"
                    android:padding="12dp"
                    android:hint="Enter your position"
                    android:textSize="14sp"
                    android:fontFamily="@font/poppins"
                    android:enabled="false"/>

                <!-- Password -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="New Password"
                    android:textSize="14sp"
                    android:textColor="#1F2937"
                    android:fontFamily="@font/poppins"
                    android:layout_marginTop="12dp"/>

                <EditText
                    android:id="@+id/etPassword"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/edittext_line_background"
                    android:padding="12dp"
                    android:hint="Leave blank to keep current"
                    android:inputType="textPassword"
                    android:textSize="14sp"
                    android:fontFamily="@font/poppins"
                    android:enabled="false"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── PREFERENCES CARD ───────────────────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Preferences"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#111827"
            android:fontFamily="@font/poppins"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="12dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="6dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="10dp">

                <!-- Dark Mode -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="4dp">

                    <TextView
                        android:text="Dark Mode"
                        android:textSize="17sp"
                        android:textColor="#1F2937"
                        android:layout_weight="1"
                        android:fontFamily="@font/poppins"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"/>

                    <Switch
                        android:id="@+id/switchDarkMode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:enabled="false"/>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E5E7EB"/>

                <!-- Notifications -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="4dp">

                    <TextView
                        android:text="Notifications"
                        android:textSize="17sp"
                        android:textColor="#1F2937"
                        android:layout_weight="1"
                        android:fontFamily="@font/poppins"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"/>

                    <Switch
                        android:id="@+id/switchNotifications"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:enabled="false"/>
                </LinearLayout>

                <!-- Edit / Save button -->
                <Button
                    android:id="@+id/btnSubmit"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="Edit Settings"
                    android:backgroundTint="#0984E3"
                    android:textColor="#fff"
                    android:textStyle="bold"
                    android:fontFamily="@font/poppins"
                    android:layout_marginTop="16dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── SUPPORT CARD ───────────────────────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Support"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#111827"
            android:fontFamily="@font/poppins"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="12dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="6dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="10dp">

                <TextView
                    android:id="@+id/btnHelp"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="Help Center"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="8dp"
                    android:drawableStart="@drawable/ic_question"
                    android:drawablePadding="10dp"
                    android:fontFamily="@font/poppins"
                    android:textSize="17sp"
                    android:textColor="#1F2937"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E5E7EB"/>

                <TextView
                    android:id="@+id/btnContact"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="Contact Us"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="8dp"
                    android:drawableStart="@drawable/ic_support1"
                    android:drawablePadding="10dp"
                    android:fontFamily="@font/poppins"
                    android:textSize="17sp"
                    android:textColor="#1F2937"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E5E7EB"/>

                <!-- App Version -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="App Version: 1.0.0"
                    android:textSize="14sp"
                    android:fontFamily="@font/poppins"
                    android:textColor="#6B7280"
                    android:layout_marginTop="12dp"
                    android:layout_marginStart="8dp"
                    android:layout_marginBottom="4dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── LOGOUT ─────────────────────────────────────────────────────── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="6dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:id="@+id/btnLogout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Logout"
                android:gravity="center"
                android:padding="16dp"
                android:fontFamily="@font/poppins"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#D32F2F"/>

        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
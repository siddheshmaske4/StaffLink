<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="2dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="4dp"
    app:cardUseCompatPadding="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Employee email — shown only in admin view -->
        <TextView
            android:id="@+id/txtLeaveEmployee"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="employee@example.com"
            android:textSize="12sp"
            android:fontFamily="@font/poppins"
            android:textColor="#888"
            android:visibility="gone"/>

        <!-- Title + Leave type row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="2dp">

            <TextView
                android:id="@+id/txtLeaveTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Leave Title"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#111"
                android:fontFamily="@font/poppins"/>

            <TextView
                android:id="@+id/txtLeaveType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Full Day"
                android:textSize="12sp"
                android:textStyle="bold"
                android:fontFamily="@font/poppins"
                android:textColor="#1E90FF"/>

        </LinearLayout>

        <!-- Body / reason -->
        <TextView
            android:id="@+id/txtLeaveBody"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Reason for leave"
            android:textSize="14sp"
            android:fontFamily="@font/poppins"
            android:textColor="#555"
            android:layout_marginTop="4dp"/>

        <!-- Date -->
        <TextView
            android:id="@+id/txtLeaveDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="01 Jan 2026, 10:00 AM"
            android:textSize="12sp"
            android:fontFamily="@font/poppins"
            android:textColor="#AAA"
            android:gravity="end"
            android:layout_marginTop="6dp"/>

    </LinearLayout>

</androidx.cardview.widget.CardView>
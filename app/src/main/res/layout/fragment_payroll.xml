<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/admin_page_gradient"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="30dp">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="My Payslip"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@android:color/black"
            android:fontFamily="@font/poppins"
            android:layout_marginBottom="16dp"/>

        <!-- Month Selector Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:elevation="8dp"
            android:radius="16dp"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Select Month"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:fontFamily="@font/poppins"
                    android:textColor="#666666"
                    android:layout_marginBottom="8dp"/>

                <Spinner
                    android:id="@+id/spinnerMonth"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Salary Details Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:elevation="10dp"
            android:radius="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Base Salary -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:id="@+id/txtBaseSalary"
                    android:text="₹0"
                    android:textSize="22sp"
                    android:fontFamily="@font/poppins"
                    android:textStyle="bold"
                    android:textColor="#1B5E20"/>

                <TextView
                    android:layout_height="match_parent"
                    android:layout_width="match_parent"
                    android:text="Base Salary"
                    android:textSize="13sp"
                    android:fontFamily="@font/poppins"
                    android:textColor="#777777"
                    android:layout_marginBottom="16dp"/>

                <!-- Row: Attendance -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:id="@+id/txtPresentDays"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Present: 0"
                        android:fontFamily="@font/poppins"
                        android:textSize="14sp"/>

                    <TextView
                        android:id="@+id/txtLeaves"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Leaves: 0"
                        android:textSize="14sp"/>
                </LinearLayout>

                <!-- Overtime -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:id="@+id/txtOvertime"
                    android:text="Overtime: 0 hrs"
                    android:fontFamily="@font/poppins"
                    android:textSize="14sp"
                    android:layout_marginBottom="12dp"/>

                <!-- PF + ESI -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:id="@+id/txtPfEsi"
                    android:fontFamily="@font/poppins"
                    android:text="PF + ESI: ₹0"
                    android:textSize="14sp"
                    android:layout_marginBottom="16dp"/>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#DDDDDD"
                    android:layout_marginBottom="16dp"/>

                <!-- Final Salary -->
                <TextView
                    android:layout_height="match_parent"
                    android:layout_width="match_parent"
                    android:text="Net Pay"
                    android:fontFamily="@font/poppins"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#555555"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:id="@+id/txtFinalSalary"
                    android:text="₹0"
                    android:textSize="26sp"
                    android:fontFamily="@font/poppins"
                    android:textStyle="bold"
                    android:textColor="#2E7D32"
                    android:layout_marginBottom="20dp"/>

                <!-- Download Button -->
                <Button
                    android:id="@+id/btnDownloadPayslip"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Download Payslip"
                    android:fontFamily="@font/poppins"
                    android:textAllCaps="false"
                    android:backgroundTint="@color/darkgreen"
                    android:padding="12dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
